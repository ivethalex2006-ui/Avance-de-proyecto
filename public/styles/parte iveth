const Producto = require('../models/Producto'); // Asegúrate de tener definido tu esquema

const getAllProductos = async (req, res) => {
    try {
        // 1. Obtener parámetros de la query (con valores por defecto)
        const page = parseInt(req.query.page) || 1;
        const limit = parseInt(req.query.limit) || 10;

        // 2. Calcular el número de documentos a saltar
        const skip = (page - 1) * limit;

        // 3. Ejecutar la consulta con skip y limit
        const productos = await Producto.find()
            .skip(skip)
            .limit(limit);

        // 4. Obtener el total de documentos para el frontend
        const totalProductos = await Producto.countDocuments();

        res.status(200).json({
            status: 'success',
            results: productos.length,
            totalPages: Math.ceil(totalProductos / limit),
            currentPage: page,
            data: productos
        });
    } catch (error) {
        res.status(500).json({ message: 'Error al obtener productos', error: error.message });
    }
};

module.exports = { getAllProductos };
